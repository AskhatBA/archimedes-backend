
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

model User {
  id                    String   @id @default(uuid()) @db.Uuid
  phone                 String    @unique
  email                 String?   @unique
  refreshToken          String?
  role                  Role      @default(PATIENT)

  patient               Patient?
  doctor                Doctor?
  otp                   OTP?
  insuranceServiceToken InsuranceServiceToken?
  deviceTokens          DeviceToken[]
  appointments          Appointment[]
  notifications         Notification[]
  insuranceRefundRequests InsuranceRefundRequest[]
}

model Patient {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @unique @db.Uuid
  firstName    String
  lastName     String
  patronymic   String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  birthDate    String
  gender       String
  iin          String        @unique
  misPatientId String        @unique
}

model Doctor {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @unique @db.Uuid
  firstName      String
  lastName       String
  patronymic     String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String
  specialization String
  licenseNumber  String        @unique
  phone          String?
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id             String            @id @default(uuid()) @db.Uuid
  userId         String            @db.Uuid
  patientId      String            @db.Uuid
  doctorId       String            @db.Uuid
  externalId     String            @db.Uuid
  dateTime       DateTime
  status         AppointmentStatus @default(SCHEDULED)
  isTelemedicine Boolean           @default(false)
  meetingUrl     String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OTP {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @unique
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
}

model InsuranceServiceToken {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid @unique
  accessToken String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InsuranceRefundRequest {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  beneficiaryId    String
  personId         String
  programId        String
  category         Int
  date             String
  amount           Float
  comments         String?
  files            Json
  externalResponse Json?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum Platform {
  IOS
  ANDROID
  WEB
}

enum AppVersionPlatform {
  IOS
  ANDROID
  ALL
}

model AppVersion {
  id                 String             @id @default(uuid()) @db.Uuid
  platform           AppVersionPlatform
  latestVersion      String
  minSupportedVersion String
  forceUpdate        Boolean            @default(false)
  changelog          String?
  createdAt          DateTime           @default(now())

  @@index([platform, createdAt])
}

model DeviceToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  deviceId  String   @unique
  platform  Platform
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum NotificationStatus {
  SENT
  DELIVERED
  FAILED
}

model Notification {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String             @db.Uuid
  title            String
  message          String
  data             Json?
  status           NotificationStatus @default(SENT)
  isRead           Boolean            @default(false)
  readAt           DateTime?
  oneSignalId      String?
  oneSignalResponse Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, isRead])
}
